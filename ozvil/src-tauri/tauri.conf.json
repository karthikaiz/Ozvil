{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ozvil",
  "version": "0.1.0",
  "identifier": "com.ozvil.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ozvil",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Ozvil"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Ozvil",
    "copyright": "Copyright © 2026 Ozvil",
    "category": "Utility",
    "shortDescription": "Windows workload modes for heavy apps",
    "longDescription": "Ozvil clears the runway for your Windows PC when heavy work starts, protects the session, and restores everything afterward. Profile-based automation for creators, developers, and gamers.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US",
        "template": "wix/main.wxs",
        "fragmentPaths": ["wix/safe_mode_shortcut.wxs"],
        "componentGroupRefs": ["OzvilSafeModeShortcutGroup"]
      },
      "nsis": {
        "template": "nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "license": "nsis/license.rtf",
        "installMode": "perMachine",
        "languages": ["English"],
        "customNsisFolderPath": "nsis",
        "displayLanguageSelector": false
      }
    },
    "updater": {
      "active": false,
      "dialog": true,
      "pubkey": "",
      "endpoints": [
        "https://update.ozvil.app/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installerArgs": ["/S"],
        "onInstallMode": "passive"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://update.ozvil.app/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": ["/S"],
        "onInstallMode": "passive"
      }
    }
  }
}
