{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ozvil",
  "version": "0.1.0",
  "identifier": "com.ozvil.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ozvil",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Ozvil"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US",
        "shortcutName": "Ozvil",
        "menuItems": [
          {
            "name": "Ozvil",
            "desktop": true,
            "startMenu": true
          },
          {
            "name": "Ozvil (Safe Mode)",
            "desktop": false,
            "startMenu": true,
            "arguments": "--safe-mode"
          }
        ]
      }
    }
  }
}
