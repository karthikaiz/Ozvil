{
  "name": "@ozvil/update-server",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker — Ozvil auto-update endpoint",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240502.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "wrangler": "^3.57.0"
  }
}
